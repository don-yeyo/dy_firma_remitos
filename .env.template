# Nombre del escáner en el sistema (por ejemplo, parte del nombre como 'RICOH' o el driver WIA específico)
SCANNER_NAME=RICOH IM C300 [58387958FB4C]


# Directorio de salida de los documentos escaneados
SCAN_OUTPUT_DIR=scanned_documents

# Resolución en DPI para el escaneo (ej. 150, 200, 300)
SCAN_DPI=200

# Formato de color: 1 = Color, 2 = Grayscale, 4 = Black & White
SCAN_COLOR_MODE=1

# Formato de archivo de imagen resultante: JPG, PNG o TIFF
SCAN_FORMAT=JPG

# Origen del papel: ADF o FLATBED
SCAN_SOURCE=ADF

# Clave API de Google Gemini (Obtener en https://aistudio.google.com/)
GEMINI_API_KEY=tu_clave_api_aqui

# Proveedor de Inteligencia Artificial: gemini (en la nube) o local_vlm (Ollama/vLLM local)
AI_PROVIDER=gemini

# Configuración del VLM Local (Ollama / vLLM)
# Para Ollama local usar base_url http://localhost:11434/v1 y api_key 'ollama'
# Para vLLM o proxy en producción usar la URL y token respectivos
VLM_API_URL=http://localhost:11434/v1
VLM_API_KEY=ollama
VLM_MODEL=qwen2.5vl-large-ctx

# Tamaño de contexto del modelo de visión (Qwen2.5-VL requiere al menos 8192 o 16384 para procesar imágenes)
VLM_NUM_CTX=16384




