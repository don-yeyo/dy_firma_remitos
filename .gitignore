# Entornos virtuales
.venv/
venv/
ENV/
env/

# Caché de Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Variables de entorno locales
.env
.env.local
.env.*.local

# Salidas de escaneo y temporales (se crean automáticamente al ejecutar)
scanned_documents/
tmp/
*.jpg
*.jpeg
*.png
*.pdf

# Carpeta de salida de documentos procesados/extraídos
parsed_documents/

# Modelos descargados locales
models/
*.tflite

# Archivos temporales o de documentación redundantes en formato binario
docs/*.docx

# Configuración de editores e IDEs comunes
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Archivos del sistema operativo
Thumbs.db
Desktop.ini
.DS_Store

# Node.js
client/node_modules/
node_modules/
client/dist/

# PyInstaller y compilaciones del servidor
server/build/
server/dist/
server/*.spec
dist_server/
*.spec
build/
dist/

# Exclusiones recursivas de entornos y configuraciones locales
**/.env
**/server/.env
**/client/.env
**/.env.local
**/.env.*.local
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.venv/
venv/

server/logs/