[Install.RScan]
Include=sti.inf
Needs=STI.SerialSection
SubClass=StillImage
Connection=Serial
DeviceType=1
; 0=Net/1=SCSIor1394/3=USB
DeviceSubType=0
Capabilities=0x30

DeviceData=RScan.DeviceData
AddReg=RScan.AddReg
CopyFiles=RScan.CopyFiles, RScan.TextFile, RScan.LicenseFiles, RScan.ProfileFiles, RScan.ScanCtrlFiles, RScan.UIFiles, RScan.System, RScan.English, RScan.Simplechn, RScan.Common
;ICMProfiles="is330.icm"
;PortSelect=Message1
Events=RScan.Events

[RScan.Events]

[Install.RScan.Services]
Include=sti.inf
Needs=STI.SerialSection.Services

[RScan.DeviceData]
Server=local
UI Class ID=%UID_UI%

