[RScan.AddReg]
HKR,,HardwareConfig,1,1
HKR,,USDClass,,%UID_USD%
HKCR,CLSID\%UID_USD%,,,"%Mfg% WIA Scanner"
HKCR,CLSID\%UID_USD%\InProcServer32,,,%16422%\%Mfg%\WIA\%MODEL_PATH%\RWiaDrv.dll
HKCR,CLSID\%UID_USD%\InProcServer32,ThreadingModel,,"Both"

; Error Handler
HKCR,CLSID\%UID_UI%\shellex\ErrorHandler\%UID_ERR%
HKCR,CLSID\%UID_ERR%,,,"%Mfg% WIA Error Handler"
HKCR,CLSID\%UID_ERR%\InProcServer32,,,%16422%\%Mfg%\WIA\%MODEL_PATH%\RWiaErrorHandler.dll
HKCR,CLSID\%UID_ERR%\InProcServer32,ThreadingModel,,"Both"

; Ext UI
HKCR,CLSID\%UID_UI%\shellex\WiaDialogExtensionHandlers\%UID_EUI%
HKCR,CLSID\%UID_EUI%,,,"%Mfg% WIA Dialog Extension Handler"
HKCR,CLSID\%UID_EUI%\InProcServer32,,,%16422%\%Mfg%\WIA\%MODEL_PATH%\RWiaExt.dll
HKCR,CLSID\%UID_EUI%\InProcServer32,ThreadingModel,,"Apartment"

; Property Sheet UI
HKCR,CLSID\%UID_UI%\shellex\PropertySheetHandlers\%UID_SUI%
HKCR,CLSID\%UID_SUI%,,,"%Mfg% WIA Property Sheet Handler"
HKCR,CLSID\%UID_SUI%\InProcServer32,,,%16422%\%Mfg%\WIA\%MODEL_PATH%\RWiaExt.dll
HKCR,CLSID\%UID_SUI%\InProcServer32,ThreadingModel,,"Apartment"

