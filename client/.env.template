# Configuración de Autenticación de Microsoft Azure AD para el Frontend React
VITE_AZURE_AD_CLIENT_ID=tu_client_id_aqui
VITE_AZURE_AD_TENANT_ID=tu_tenant_id_aqui

# URL del servidor backend de FastAPI
# Desarrollo local: http://localhost:8000
# Produccion (ngrok): https://tu-dominio.ngrok-free.app
VITE_API_URL=http://localhost:8000

# Bypass de autenticación para desarrollo local
# Establecer a true para simular un inicio de sesión corporativo en desarrollo sin configurar Azure AD
VITE_MOCK_AUTH=true
VITE_MOCK_AUTH_EMAIL=operador.remitos@donyeyo.com.ar

# Visibilidad de tarjetas de acción (por defecto true, establecer a false para ocultar)
VITE_MOSTRAR_ESCAN_PROC_TODO=true
VITE_MOSTRAR_ESCAN_MASIVO=true
VITE_MOSTRAR_PROCESAR_IA=true
VITE_MOSTRAR_ACTUALIZA_REMITOS=true
